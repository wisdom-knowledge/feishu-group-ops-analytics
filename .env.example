# 飞书开放平台企业自建应用
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_me

# 群配置与归档目录
GROUPS_CONFIG=./groups.json
PEOPLE_CONFIG=./people.json
PROJECT_EVENTS_CONFIG=./project-events.json
ARCHIVE_DIR=./data

# 默认增量策略
LOOKBACK_HOURS=24
OVERLAP_MINUTES=5

# 云库存储：配置后同步、报表、看板都会以 ByteHouse 为主库
# STORAGE_PROVIDER=bytehouse
# BYTEHOUSE_HOST=your-bytehouse-public-domain
# BYTEHOUSE_PORT=8123
# BYTEHOUSE_PROTOCOL=https
# BYTEHOUSE_USER=bytehouse
# BYTEHOUSE_PASSWORD=your-api-key-or-db-password
# BYTEHOUSE_DATABASE=your_database
# BYTEHOUSE_VIRTUAL_WAREHOUSE=vw-xxx
# BYTEHOUSE_TABLE_PREFIX=feishu_group_analysis

# AI 分析，可用 OpenRouter 或 OpenAI 兼容接口
# AI_ENABLED=1
# OPENROUTER_API_KEY=sk-or-xxx
# AI_MODEL=qwen/qwen-2.5-72b-instruct
# AI_BASE_URL=https://openrouter.ai/api/v1
